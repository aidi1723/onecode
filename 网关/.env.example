# Copy this file to .env and fill values on each tester machine.
# Never commit .env.

# Gateway bind address.
ONEWORD_HOST=127.0.0.1
ONEWORD_PORT=8080

# Token accepted by the gateway from local clients.
# Friends should use this as the client-side API key when pointing Claude Code/Codex at the gateway.
ONEWORD_GATEWAY_TOKEN=change-me-local-gateway-token

# Workspace inspected by native_inspect_card.
# Use an absolute path for best results.
ONEWORD_WORKSPACE_ROOT=/absolute/path/to/project-under-test

# OpenAI-compatible upstream, for /v1/chat/completions.
ONEWORD_UPSTREAM_BASE_URL=https://api.openai.com/v1
ONEWORD_UPSTREAM_API_KEY=

# Anthropic-compatible upstream, for Claude Code /v1/messages.
# Examples:
#   https://api.anthropic.com/v1
#   https://api.moonshot.cn/anthropic/v1
#   http://10.0.0.184:6780/v1
ONEWORD_ANTHROPIC_BASE_URL=https://api.anthropic.com/v1
ONEWORD_ANTHROPIC_API_KEY=
ONEWORD_ANTHROPIC_MODEL=claude-sonnet-4-6

# Optional OpenAI-compatible model for Codex Desktop / Codex CLI tests.
# Leave empty to reuse ONEWORD_ANTHROPIC_MODEL in deploy/run_codex_smoke.sh.
ONEWORD_CODEX_MODEL=

# Optional hardening flags for later physical verification stages.
ONEWORD_PROTECT_PREFLIGHT=0
ONEWORD_REQUIRE_DOCKER_FOR_VERIFY=0
ONEWORD_REQUIRE_GUARD_SCANNER=0
