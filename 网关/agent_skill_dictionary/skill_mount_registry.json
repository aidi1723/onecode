      ],
      "evidence": [
        "json_choice_prompt",
        "user_confirmation",
        "structured_answer"
      ]
    },
    "记": {
      "mount_name": "memory_bank_mount",
      "purpose": "挂载 CLAUDE.md / Memory Bank / ADR 记忆规范，只保存已验证、可复用的项目事实和决策。",
      "community_sources": [
        {
          "name": "Claude Code memory",
