FROM python:3.12-slim

WORKDIR /app

COPY requirements-gateway.txt /app/requirements-gateway.txt
RUN pip install --no-cache-dir -r /app/requirements-gateway.txt

COPY agent_skill_dictionary /app/agent_skill_dictionary

ENV ONEWORD_DICTIONARY_PATH=/app/agent_skill_dictionary/programming-agent-skill-dictionary.json
ENV ONEWORD_UPSTREAM_BASE_URL=https://api.openai.com/v1

EXPOSE 8080

CMD ["uvicorn", "agent_skill_dictionary.gateway_server:app", "--host", "0.0.0.0", "--port", "8080"]
